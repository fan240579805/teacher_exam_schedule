# 深教考通本地配置示例
# 复制为 .env.local 后填写。不要提交 .env.local 或任何真实密钥。

# Supabase Project URL，例如 https://xxxx.supabase.co
VITE_SUPABASE_URL=

# Supabase anon public key，仅允许填写 anon key。严禁把 service_role key 放入客户端。
VITE_SUPABASE_ANON_KEY=

# 微信小程序 AppID。真实值请在 apps/app/src/manifest.json 或环境注入中填写。
VITE_WEIXIN_APPID=

# 可选：开启本地 mock。缺少 Supabase 配置时应用会自动 fallback 到 mock。
VITE_USE_MOCK=true
